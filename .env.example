# ── MVP Automation Platform — Konfiguracja LLM ──────────────
#
# Skopiuj ten plik:  cp .env.example .env
# Uzupełnij klucz API i uruchom:  docker compose up --build
#
# LiteLLM obsługuje 100+ providerów — wystarczy ustawić
# odpowiedni klucz API i LLM_MODEL.

# ── OpenRouter (domyślny) ────────────────────────────────────
OPENROUTER_API_KEY=

# Uzupełniaj brakujące body e-maila przez LLM (wymaga OPENROUTER_API_KEY)
# NLP_ENRICH_MISSING=1
LLM_MODEL=openrouter/openai/gpt-5-mini

# ── OpenAI ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# ── Anthropic ────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514

# ── Ollama (lokalny, bez klucza) ─────────────────────────────
# OLLAMA_API_BASE=http://localhost:11434
# LLM_MODEL=ollama/llama3

# ── Groq (szybki, darmowy tier) ──────────────────────────────
# GROQ_API_KEY=gsk_
# LLM_MODEL=groq/llama-3.1-8b-instant

# ── Together AI ──────────────────────────────────────────────
# TOGETHER_API_KEY=
# LLM_MODEL=together_ai/meta-llama/Llama-3-8b-chat-hf

# ── Mistral ──────────────────────────────────────────────────
# MISTRAL_API_KEY=
# LLM_MODEL=mistral/mistral-small-latest

# ── Azure OpenAI ─────────────────────────────────────────────
# AZURE_API_KEY=
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview
# LLM_MODEL=azure/your-deployment-name

# ── Custom / Self-hosted ─────────────────────────────────────
# LLM_API_BASE=http://your-server:8080/v1
# LLM_MODEL=openai/your-model

# ── LLM Settings ─────────────────────────────────────────────
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
LLM_FALLBACK_THRESHOLD=0.5

# ── Host ports ───────────────────────────────────────────────
# 8002 jest zajęty przez Mullm Projector, gdy oba stacki działają równolegle.
NLP2DSL_BACKEND_HOST_PORT=8010
NLP2DSL_NLP_HOST_PORT=8012
NLP2DSL_WORKER_HOST_PORT=8004
NLP2DSL_CONFIG=./nlp2dsl.yaml
NLP2DSL_AGENT_ID=user

# ── Speech-to-Text (Deepgram) ────────────────────────────────
# Deepgram API Key dla STT (Speech-to-Text)
# Zdobądź klucz: https://console.deepgram.com/
DEEPGRAM_API_KEY=
