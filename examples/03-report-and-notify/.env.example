# Konfiguracja API NLP2DSL
NLP2DSL_API_URL=http://localhost:8010

# Konfiguracja Slack (opcjonalne - do prawdziwych powiadomień)
# Jeśli nie skonfigurowane, system użyje mock responses
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Alternatywnie: Webhook URL (prostsza integracja)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Konfiguracja generowania raportów (opcjonalne)
REPORTS_OUTPUT_DIR=/app/reports
REPORTS_TEMPLATE_DIR=/app/templates
REPORTS_DATA_SOURCE=/app/data
