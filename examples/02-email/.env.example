# Konfiguracja API NLP2DSL
NLP2DSL_API_URL=http://localhost:8010

# Konfiguracja SMTP (opcjonalne - do prawdziwego wysyłania emaili)
# Jeśli nie skonfigurowane, system użyje mock responses
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=twoj_email@gmail.com
SMTP_PASSWORD=twoj_haslo_aplikacji
SMTP_TLS=true

# Alternatywa: MailHog (do testów lokalnych)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
