# Konfiguracja API NLP2DSL
NLP2DSL_API_URL=http://localhost:8010

# Konfiguracja SMTP (opcjonalne - do prawdziwego wysyłania faktur)
# Jeśli nie skonfigurowane, system użyje mock responses
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=twoj_email@gmail.com
SMTP_PASSWORD=twoj_haslo_aplikacji
SMTP_TLS=true

# Konfiguracja faktury (opcjonalne)
INVOICE_COMPANY_NAME="Twoja Firma Sp. z o.o."
INVOICE_COMPANY_ADDRESS="Ul. Przykładowa 1, 00-123 Warszawa"
INVOICE_COMPANY_NIP="1234567890"
INVOICE_COMPANY_BANK="PL 1234 5678 9012 3456 7890 1234 5678"
