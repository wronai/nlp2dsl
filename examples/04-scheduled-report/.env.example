# Konfiguracja API NLP2DSL
NLP2DSL_API_URL=http://localhost:8010

# Konfiguracja schedulera (opcjonalne)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Warsaw
SCHEDULER_MAX_WORKERS=3

# Konfiguracja storage dla raportów (opcjonalne)
# S3 compatible (MinIO lub AWS)
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=reports
S3_REGION=us-east-1

# Alternatywa: lokalny storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/reports
