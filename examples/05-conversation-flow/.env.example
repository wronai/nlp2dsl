# Konfiguracja API NLP2DSL
NLP2DSL_API_URL=http://localhost:8010

# Konfiguracja sesji (opcjonalne)
SESSION_TIMEOUT=3600  # 1 godzina
MAX_CONVERSATION_LENGTH=50
ENABLE_PERSISTENCE=true

# Baza danych dla historii konwersacji (opcjonalne)
# Jeśli nie skonfigurowane, system używa in-memory storage
DB_URL=postgresql://example:example@localhost:5433/examples
REDIS_URL=redis://localhost:6379/0
